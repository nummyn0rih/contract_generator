# Authorization Key из личного кабинета Sber Studio (Base64-токен)
GIGACHAT_CREDENTIALS=
# scope: GIGACHAT_API_PERS | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модель: GigaChat-2 | GigaChat-2-Pro | GigaChat-2-Max (или legacy GigaChat-Max)
GIGACHAT_MODEL=GigaChat-2-Max
# Проверять SSL-сертификат Минцифры. false — проще для разработки.
GIGACHAT_VERIFY_SSL=false
